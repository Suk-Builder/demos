# ============================================
# 曼波语音助手 — 生产环境变量配置
# 重要：此文件包含敏感信息，请勿提交到Git仓库！
# 部署前请将 .env.production.example 复制为 .env.production 并填入实际值
# ============================================

# ---- 应用基础配置 ----
# 应用名称
APP_NAME=曼波语音助手
# 运行环境（production/staging/development）
NODE_ENV=production
# 服务端口（后端API端口）
PORT=3001

# ---- 前端配置（构建时注入） ----
# API基础路径（相对路径，通过Nginx反向代理）
VITE_API_BASE_URL=/api
# WebSocket地址（用于实时通信）
VITE_WS_URL=wss://mambo.sukaczev.top/ws
# 应用显示名称
VITE_APP_NAME=曼波语音助手
# 最大历史消息数
VITE_MAX_HISTORY=50

# ---- 域名配置 ----
# 主域名
DOMAIN=mambo.sukaczev.top
# 完整URL
APP_URL=https://mambo.sukaczev.top
# 允许的前端来源（CORS）
CORS_ORIGIN=https://mambo.sukaczev.top

# ---- 数据库配置（PostgreSQL） ----
# 完整数据库连接URL
DATABASE_URL=postgres://mambo:mambo_secret@db:5432/mambo_db
# 数据库连接池最小连接数
DB_POOL_MIN=2
# 数据库连接池最大连接数
DB_POOL_MAX=10
# 数据库连接超时（毫秒）
DB_CONNECTION_TIMEOUT=5000
# PostgreSQL root密码（仅首次初始化使用）
POSTGRES_PASSWORD=change_this_to_strong_password
# 应用数据库用户密码
DB_PASSWORD=change_this_to_strong_password

# ---- 缓存配置（Redis） ----
# Redis连接URL
REDIS_URL=redis://redis:6379

# ---- DeepSeek AI API配置 ----
# DeepSeek API密钥（从DeepSeek开放平台获取）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# DeepSeek API基础地址
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 使用的模型名称
DEEPSEEK_MODEL=deepseek-chat
# 请求超时（毫秒）
AI_REQUEST_TIMEOUT=60000
# 最大上下文长度（token数）
AI_MAX_CONTEXT_LENGTH=8192

# ---- JWT认证配置 ----
# JWT签名密钥（使用强随机字符串，至少32字符）
JWT_SECRET=change_this_to_a_very_long_random_secret_key_32chars_min
# Token过期时间（秒）
JWT_EXPIRES_IN=604800
# Token刷新窗口（秒）
JWT_REFRESH_WINDOW=86400

# ---- 语音服务配置 ----
# 是否启用语音合成（TTS）
TTS_ENABLED=true
# 是否启用语音识别（STT）
STT_ENABLED=true
# 默认语音语言
VOICE_LANG=zh-CN

# ---- 日志配置 ----
# 日志级别（error/warn/info/debug）
LOG_LEVEL=info
# 日志输出路径
LOG_FILE=/app/logs/app.log
# 单日志文件最大大小（MB）
LOG_MAX_SIZE=50
# 保留日志文件数量
LOG_MAX_FILES=7

# ---- 安全相关 ----
# 请求速率限制（每分钟最大请求数）
RATE_LIMIT_PER_MINUTE=60
# 密码哈希盐轮数
BCRYPT_ROUNDS=12
# 允许的MIME类型（上传文件）
ALLOWED_MIME_TYPES=audio/webm,audio/wav,audio/mp3

# ---- SSL证书路径（服务器上Nginx使用） ----
# Let's Encrypt证书路径（使用certbot自动管理时）
SSL_CERT_PATH=/etc/letsencrypt/live/mambo.sukaczev.top/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/mambo.sukaczev.top/privkey.pem

# ============================================
# GitHub Actions Secrets 配置提示
# 在GitHub仓库 Settings -> Secrets and variables -> Actions 中添加：
#
#   DOCKERHUB_USERNAME      Docker Hub用户名
#   DOCKERHUB_TOKEN         Docker Hub访问令牌
#   DEPLOY_HOST             部署服务器IP/域名
#   DEPLOY_USER             SSH用户名
#   DEPLOY_KEY              SSH私钥
#   DEPLOY_PORT             SSH端口（默认22）
#
# ============================================
